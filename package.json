{
	"name": "psake-vscode",
	"displayName": "psake",
	"publisher": "psake",
	"description": "Psake build script language support for Visual Studio Code.",
	"version": "1.1.0",
	"icon": "images/psake.png",
	"private": true,
	"author": {
		"name": "psake",
		"url": "https://psake.dev"
	},
	"bugs": {
		"url": "https://github.com/psake/psake-vscode/issues"
	},
	"homepage": "https://github.com/psake/psake-vscode",
	"repository": {
		"type": "git",
		"url": "https://github.com/psake/psake-vscode"
	},
	"galleryBanner": {
		"color": "#7E7E7C",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Programming Languages",
		"Snippets",
		"Other"
	],
	"activationEvents": [
		"onTaskType:psake",
		"workspaceContains:**/build.ps1",
		"workspaceContains:**/Build.ps1",
		"workspaceContains:**/BUILD.ps1",
		"workspaceContains:**/psake.ps1",
		"workspaceContains:**/psakefile.ps1",
		"workspaceContains:**/psakeFile.ps1",
		"workspaceContains:**/PsakeFile.ps1",
		"workspaceContains:**/PSAKEFILE.ps1"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"snippets": [
			{
				"language": "powershell",
				"path": "./snippets/powershell.json"
			}
		],
		"commands": [
			{
				"command": "psake.buildFile",
				"title": "psake: Install sample build file"
			},
			{
				"command": "psake.runTask",
				"title": "psake: Run Task",
				"icon": "$(play)"
			},
			{
				"command": "psake.refreshTasks",
				"title": "psake: Refresh Tasks",
				"icon": "$(refresh)"
			},
			{
				"command": "psake.openTaskDefinition",
				"title": "psake: Go to Task Definition"
			},
			{
				"command": "psake.syncTasks",
				"title": "psake: Sync Tasks to tasks.json"
			}
		],
		"taskDefinitions": [
			{
				"type": "psake",
				"required": [
					"task"
				],
				"properties": {
					"task": {
						"type": "string",
						"description": "The psake task name to execute."
					},
					"file": {
						"type": "string",
						"description": "The psake build file path, relative to the workspace folder. Defaults to psakefile.ps1."
					}
				}
			}
		],
		"views": {
			"explorer": [
				{
					"id": "psakeTasksView",
					"name": "psake Tasks",
					"when": "psake:hasTaskFile",
					"icon": "images/psake.png"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "psake.refreshTasks",
					"when": "view == psakeTasksView",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "psake.runTask",
					"when": "viewItem == psakeTask",
					"group": "inline"
				},
				{
					"command": "psake.openTaskDefinition",
					"when": "viewItem == psakeTask",
					"group": "navigation"
				}
			],
			"commandPalette": [
				{
					"command": "psake.runTask",
					"when": "false"
				},
				{
					"command": "psake.openTaskDefinition",
					"when": "false"
				}
			]
		},
		"configuration": {
			"title": "psake",
			"properties": {
				"psake.buildFile": {
					"type": "string",
					"default": "psakefile.ps1",
					"description": "The default name for the psake build file."
				},
				"psake.taskProvider.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable automatic detection of psake tasks from the build file."
				},
				"psake.buildScript": {
					"type": "string",
					"default": "",
					"description": "Path to a wrapper build script (e.g., build.ps1) relative to the workspace root. When empty, the extension auto-detects build.ps1 in the workspace root. Set to \"none\" to disable build script usage and call Invoke-psake directly."
				},
				"psake.buildScriptTaskParameter": {
					"type": "string",
					"default": "Task",
					"description": "The parameter name on the build script that accepts the task name (e.g., \"Task\" for -Task <name>)."
				},
				"psake.codeLens.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Show '▶ Run Task' CodeLens above each task declaration in the psake build file."
				},
				"psake.powershellExecutable": {
					"type": "string",
					"default": "",
					"description": "Path or name of the PowerShell executable to use when running psake tasks (e.g., \"pwsh\", \"powershell\", or a full path). When empty, the extension auto-detects pwsh or powershell."
				},
				"psake.shellArgs": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"-NoProfile"
					],
					"description": "Arguments passed to the PowerShell executable before -Command when running psake tasks. The -Command switch is always appended automatically."
				},
				"psake.invokeParameters": {
					"type": "string",
					"default": "",
					"description": "Extra parameters appended to the Invoke-psake call when no build script wrapper is used (e.g., \"-nologo -properties @{Configuration='Release'}\")."
				},
				"psake.buildScriptParameters": {
					"type": "string",
					"default": "",
					"description": "Extra parameters appended to the build script call when a build script wrapper is used (e.g., \"-Configuration Release -Clean\")."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run build",
		"build": "npm run compile && node esbuild.mjs --production",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"test": "npm run build && node ./dist/test/test/runTest.js",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.7",
		"@types/node": "^20.14.0",
		"@types/vscode": "^1.90.0",
		"@vscode/test-electron": "^2.4.0",
		"@vscode/vsce": "^3.1.0",
		"esbuild": "^0.23.0",
		"mocha": "^10.6.0",
		"typescript": "~5.5.0"
	},
	"extensionDependencies": [
		"ms-vscode.PowerShell"
	],
	"funding": [
		{
			"type": "opencollective",
			"url": "https://opencollective.com/psake"
		}
	],
	"license": "MIT",
	"keywords": [
		"psake",
		"build",
		"automation",
		"powershell",
		"vscode",
		"tasks"
	]
}