{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"moduleResolution": "Node16",
		"outDir": "dist",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"noFallthroughCasesInSwitch": true,
		"allowUnreachableCode": false,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"alwaysStrict": true,
		"noImplicitThis": true,
		"strict": true
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules",
		"src/test"
	]
}
