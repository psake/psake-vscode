{
	"name": "psake-vscode",
	"displayName": "psake",
	"publisher": "psake",
	"description": "Psake build script language support for Visual Studio Code.",
	"version": "1.0.0",
	"icon": "images/psake.png",
	"private": true,
	"author": {
		"name": "psake"
	},
	"bugs": {
		"url": "https://github.com/psake/psake-vscode/issues"
	},
	"homepage": "https://github.com/psake/psake-vscode",
	"repository": {
		"type": "git",
		"url": "https://github.com/psake/psake-vscode"
	},
	"galleryBanner": {
		"color": "#FFE05C",
		"theme": "light"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Languages",
		"Snippets",
		"Other"
	],
	"activationEvents": [
		"workspaceContains:**/psakefile.ps1",
		"onTaskType:psake"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"snippets": [
			{
				"language": "powershell",
				"path": "./snippets/powershell.json"
			}
		],
		"commands": [
			{
				"command": "psake.buildFile",
				"title": "psake: Install sample build file"
			},
			{
				"command": "psake.runTask",
				"title": "psake: Run Task",
				"icon": "$(play)"
			},
			{
				"command": "psake.refreshTasks",
				"title": "psake: Refresh Tasks",
				"icon": "$(refresh)"
			},
			{
				"command": "psake.openTaskDefinition",
				"title": "psake: Go to Task Definition"
			}
		],
		"taskDefinitions": [
			{
				"type": "psake",
				"required": [
					"task"
				],
				"properties": {
					"task": {
						"type": "string",
						"description": "The psake task name to execute."
					},
					"file": {
						"type": "string",
						"description": "The psake build file path, relative to the workspace folder. Defaults to psakefile.ps1."
					}
				}
			}
		],
		"views": {
			"explorer": [
				{
					"id": "psakeTasksView",
					"name": "psake Tasks",
					"when": "psake:hasTaskFile",
					"icon": "images/psake.png"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "psake.refreshTasks",
					"when": "view == psakeTasksView",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "psake.runTask",
					"when": "viewItem == psakeTask",
					"group": "inline"
				},
				{
					"command": "psake.openTaskDefinition",
					"when": "viewItem == psakeTask",
					"group": "navigation"
				}
			]
		},
		"configuration": {
			"title": "psake",
			"properties": {
				"psake.buildFile": {
					"type": "string",
					"default": "psakefile.ps1",
					"description": "The default name for the psake build file."
				},
				"psake.taskProvider.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable automatic detection of psake tasks from the build file."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "node esbuild.mjs --production",
		"build": "node esbuild.mjs",
		"watch": "node esbuild.mjs --watch",
		"compile-tests": "tsc -p tsconfig.test.json",
		"pretest": "npm run compile-tests && node esbuild.mjs",
		"test": "node ./dist/test/runTest.js",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.7",
		"@types/node": "^20.14.0",
		"@types/vscode": "^1.90.0",
		"@vscode/test-electron": "^2.4.0",
		"@vscode/vsce": "^3.1.0",
		"esbuild": "^0.23.0",
		"mocha": "^10.6.0",
		"typescript": "~5.5.0"
	},
	"extensionDependencies": [
		"ms-vscode.PowerShell"
	]
}
